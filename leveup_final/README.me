CREATE DATABASE IF NOT EXISTS levelup_db;
USE levelup_db;

-- 1. 用户表 (优化了权限和唯一登录凭证)
CREATE TABLE users (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    email VARCHAR(100) UNIQUE NOT NULL,  -- 推荐：用邮箱或唯一账号名登录
    name VARCHAR(50) NOT NULL,           -- 用户的昵称/显示名
    password VARCHAR(255) NOT NULL,      -- 必须存储 BCrypt 加密后的Hash！
    height FLOAT,
    weight FLOAT,
    gender VARCHAR(10),
    goal VARCHAR(50),                    -- 减脂/增肌/塑形
    xp INT DEFAULT 0,                    -- 经验值 (Level UP 核心)
    streak_days INT DEFAULT 0,           -- 连续打卡天数
    role VARCHAR(20) DEFAULT 'USER',     -- 权限角色 (USER/ADMIN)，Spring Security需要
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 2. 体重/身体数据历史表 (新增：健身App必备功能)
CREATE TABLE body_metrics_history (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    user_id BIGINT NOT NULL,
    record_date DATE NOT NULL,
    weight FLOAT NOT NULL,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

-- 3. 训练计划表 (关联不变)
CREATE TABLE workout_plans (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    user_id BIGINT NOT NULL,
    plan_date DATE NOT NULL,
    is_finished BOOLEAN DEFAULT FALSE,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

-- 4. 训练动作明细
CREATE TABLE workout_exercises (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    plan_id BIGINT NOT NULL,
    exercise_name VARCHAR(100) NOT NULL,
    sets INT NOT NULL,
    reps INT NOT NULL,
    weight_kg FLOAT,
    FOREIGN KEY (plan_id) REFERENCES workout_plans(id) ON DELETE CASCADE
);

-- 5. 饮食记录表
CREATE TABLE diet_plans (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    user_id BIGINT NOT NULL,
    diet_date DATE NOT NULL,
    meal_type ENUM('breakfast', 'lunch', 'dinner', 'snack'), -- 加了个零食选项
    food_name VARCHAR(100) NOT NULL,
    calories FLOAT NOT NULL,
    protein FLOAT,
    carbs FLOAT,
    fat FLOAT,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

-- 6. 奖杯/成就字典表 (新增：配合你的 Trophy Room 页面)
CREATE TABLE trophies (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100) NOT NULL,          -- 奖杯名称，例如 "First Workout!"
    description VARCHAR(255),            -- 获取条件
    icon_url VARCHAR(255),               -- 奖杯图标的图片路径
    required_xp INT DEFAULT 0            -- 需要多少经验值解锁
);

-- 7. 用户获取奖杯记录表 (新增：多对多关系)
CREATE TABLE user_trophies (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    user_id BIGINT NOT NULL,
    trophy_id BIGINT NOT NULL,
    earned_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
    FOREIGN KEY (trophy_id) REFERENCES trophies(id) ON DELETE CASCADE
);


对于workout_exercises表的更新
1. 设计思路
exercises 表：存储所有基础动作信息，每个动作拥有唯一的名称、所属部位类别、器械类型。作为动作字典，避免重复存储动作名称。

workout_exercises 表：存储具体训练计划中的条目，通过 exercise_id 关联 exercises 表，同时记录组数、次数、重量、顺序等计划特定信息。这样既减少冗余，又便于维护动作库。

2. 创建基础动作表 exercises
CREATE TABLE exercises (
    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100) NOT NULL UNIQUE COMMENT '动作英文名',
    category VARCHAR(50) NOT NULL COMMENT '身体部位: chest, shoulders, back, legs, core, cardio',
    equipment_type VARCHAR(20) NOT NULL COMMENT 'bodyweight 或 equipment'
);

