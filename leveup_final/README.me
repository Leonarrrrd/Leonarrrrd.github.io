    id BIGINT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    goal VARCHAR(50),
    difficulty VARCHAR(50)
);

-- 2. 创建模板动作明细表
CREATE TABLE IF NOT EXISTS template_exercises (
