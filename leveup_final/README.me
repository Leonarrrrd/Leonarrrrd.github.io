    sets INT NOT NULL,
    reps INT NOT NULL,
    weight_kg FLOAT DEFAULT NULL,
    order_index INT DEFAULT 0,
    FOREIGN KEY (template_id) REFERENCES workout_templates(id) ON DELETE CASCADE
);


